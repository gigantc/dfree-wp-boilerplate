{
  "name": "dFrees WP Boilerplate",
  "version": "4.2.0",
  "description": "Built for Someone Special",
  "scripts": {
    "blocks:generate": "node scripts/generate-blocks-scss.js",
    "blocks:generate:watch": "nodemon --watch blocks --watch components --watch singles --ext scss --exec 'npm run blocks:generate'",
    "blocks:js": "node scripts/bundle-block-js.js",
    "blocks:js:prod": "node scripts/bundle-block-js.js --prod",
    "blocks:js:watch": "nodemon --watch blocks --ext js --ignore 'blocks/**/_*.js' --exec 'npm run blocks:js'",
    "components:js": "node scripts/bundle-component-js.js",
    "components:js:prod": "node scripts/bundle-component-js.js --prod",
    "components:js:watch": "nodemon --watch components --ext js --ignore 'components/**/_*.js' --exec 'npm run components:js'",
    "singles:js": "node scripts/bundle-single-js.js",
    "singles:js:prod": "node scripts/bundle-single-js.js --prod",
    "singles:js:watch": "nodemon --watch singles --ext js --ignore 'singles/**/_*.js' --exec 'npm run singles:js'",
    "css:compile": "sass src/scss/main.scss:dist/css/main.css --style=compressed --no-source-map --load-path=.",
    "css:prefix": "postcss dist/css/main.css --replace",
    "css:build": "npm run css:compile && npm run css:prefix",
    "css:watch": "sass src/scss/main.scss:dist/css/main.css --watch --embed-source-map --load-path=.",
    "css:admin:compile": "sass src/scss/admin.scss:dist/css/admin.css --style=compressed --no-source-map --load-path=.",
    "css:admin:prefix": "postcss dist/css/admin.css --replace",
    "css:admin:build": "npm run css:admin:compile && npm run css:admin:prefix",
    "css:admin:watch": "sass src/scss/admin.scss:dist/css/admin.css --watch --embed-source-map --load-path=.",
    "css:login:compile": "sass src/scss/login.scss:dist/css/login.css --style=compressed --no-source-map --load-path=.",
    "css:login:prefix": "postcss dist/css/login.css --replace",
    "css:login:build": "npm run css:login:compile && npm run css:login:prefix",
    "css:login:watch": "sass src/scss/login.scss:dist/css/login.css --watch --embed-source-map --load-path=.",
    "js:libs": "esbuild src/js/libs/modernizr.min.js --bundle --minify --outfile=dist/js/libs/libs.min.js --sourcemap",
    "js:libs:prod": "esbuild src/js/libs/modernizr.min.js --bundle --minify --outfile=dist/js/libs/libs.min.js",
    "js:main": "node scripts/bundle-main-js.js",
    "js:main:prod": "node scripts/bundle-main-js.js --prod",
    "js:main:watch": "nodemon --watch src/js --ext js --ignore 'src/js/libs/**' --exec 'npm run js:main'",
    "js:watch": "concurrently \"esbuild src/js/libs/modernizr.min.js --bundle --minify --outfile=dist/js/libs/libs.min.js --sourcemap --watch\" \"npm:js:main:watch\"",
    "sync": "sleep 3 && browser-sync start --proxy dfreeboilerplate.local --files '**/*.php' 'dist/**/*.css' 'dist/**/*.js' 'blocks/**/*.scss' --ignore 'node_modules' --reload-delay 200 --reload-debounce 2000",
    "dev": "node scripts/ensure-dist-dirs.js && npm run blocks:generate && npm run css:login:build && concurrently --kill-others \"npm:css:watch\" \"npm:css:admin:watch\" \"npm:css:login:watch\" \"npm:js:watch\" \"npm:blocks:js:watch\" \"npm:components:js:watch\" \"npm:singles:js:watch\" \"npm:blocks:generate:watch\" \"npm:sync\"",
    "build": "node scripts/ensure-dist-dirs.js && npm run blocks:generate && npm run css:login:build && npm run blocks:js:prod && npm run components:js:prod && npm run singles:js:prod && npm run css:build && npm run css:admin:build && npm run js:libs:prod && npm run js:main:prod",
    "clean": "rm -rf dist/css/*.css dist/css/*.map dist/js/*.min.js dist/js/*.map dist/js/libs/*.min.js dist/js/libs/*.map dist/js/blocks/*.min.js dist/js/blocks/*.map dist/js/components/*.min.js dist/js/components/*.map dist/js/singles/*.min.js dist/js/singles/*.map"
  },
  "author": "dFree",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "autoprefixer": "^10.4.22",
    "browser-sync": "^3.0.3",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.2",
    "nodemon": "^3.1.9",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "sass": "^1.86.3"
  }
}
